# =============================================================================
# dotMD Configuration
# =============================================================================
# Copy to .env and adjust values for the deployment you are running.
# Usage: docker compose --env-file .env up

# -- Compose -----------------------------------------------------------------
# Host path for data volume mount (default: current directory)
# DOTMD_DATA_VOLUME=.

# -- Required deployment configuration -------------------------------------
DOTMD_DATA_DIR=/mnt
DOTMD_INDEX_DIR=/dotmd-index
DOTMD_INDEXING__PATHS=["/mnt"]

# Path filtering
# Product defaults belong in ~/.dotmd/config.toml under nested sections such as
# [embedding], [indexing], [extraction], and [surreal_retrieval].
# The env file only needs runtime-specific overrides and secrets.

# DOTMD_INDEXING__EXTRA_EXCLUDE is the preferred additive operator setting. It
# preserves dotMD's built-in excludes such as **/.git and **/node_modules while
# adding deployment-specific ignore patterns.
# DOTMD_INDEXING__EXTRA_EXCLUDE=["**/private","**/drafts"]
# DOTMD_INDEXING__EXCLUDE is the replace-only setting for replacing the
# whole exclude list. Use it only when replacing built-in excludes is intended.
# DOTMD_INDEXING__EXCLUDE=["**/node_modules","**/.git"]

# TEI-compatible embedding endpoint used by normal indexing/search.
DOTMD_EMBEDDING__URL=http://tei:80

# Standalone SurrealDB is the production storage and retrieval backend.
# `index.db` remains migration/internal-cache scaffolding only.
DOTMD_SURREAL_RETRIEVAL__URL=http://surrealdb:8000
DOTMD_SURREAL_RETRIEVAL__NAMESPACE=dotmd
DOTMD_SURREAL_RETRIEVAL__DATABASE=production
DOTMD_SURREAL_RETRIEVAL__USERNAME=root
DOTMD_SURREAL_RETRIEVAL__PASSWORD=change-me
DOTMD_SURREAL_RETRIEVAL__EMBEDDING_DIMENSION=1024
DOTMD_SURREAL_RETRIEVAL__HNSW_EF=40
DOTMD_SURREAL_RETRIEVAL__VECTOR_INDEX_TYPE=F16
DOTMD_SURREAL_RETRIEVAL__EMBEDDING_SHARD_COUNT=1

# -- Index/search identity --------------------------------------------------
DOTMD_EMBEDDING__MODEL=BAAI/bge-small-en-v1.5
DOTMD_INDEXING__CHUNK_STRATEGY=heading_512_50
DOTMD_EXTRACTION__DEPTH=ner
DOTMD_EXTRACTION__NER_MODEL_NAME=urchade/gliner_multi-v2.1
DOTMD_RERANKER_NAME=mmarco-minilm
DOTMD_RERANKER_BACKEND=cross_encoder
DOTMD_RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
DOTMD_RERANKER_COMPARE_NAMES=mmarco-minilm
DOTMD_EMBEDDING__WEIGHTS=text=0.7,meta=0.3

# -- Optional features ------------------------------------------------------
# Public HTTPS base URL for OAuth-enabled MCP deployments. Leave unset to keep
# OAuth disabled for stdio and internal-network MCP transports.
# DOTMD_BASE_URL=
DOTMD_INDEXING__PROFILE=false

# -- Advanced tuning --------------------------------------------------------
DOTMD_EMBEDDING__TEI_BATCH_SIZE=4
DOTMD_GRAPH_MAX_HOPS=2
DOTMD_DEFAULT_TOP_K=10
DOTMD_FUSION_K=60
DOTMD_RERANK_POOL_SIZE=20
DOTMD_SEMANTIC_SCORE_FLOOR=0.85
DOTMD_SNIPPET_LENGTH=300
DOTMD_RERANKER_RELEVANCE_FLOOR=
DOTMD_RERANKER_LENGTH_PENALTY=true
DOTMD_RERANKER_MIN_LENGTH=50

DOTMD_INDEXING__MAX_CHUNK_TOKENS=512
DOTMD_INDEXING__CHUNK_OVERLAP_TOKENS=50
DOTMD_INDEXING__POLL_INTERVAL_SECONDS=3600.0
