{
  "steps": [
    {
      "_comment": "All 4 lowercase tools are registered with the current schemas",
      "action": "list_tools",
      "expect": {
        "tool_names_include": ["search", "read", "drill", "feedback"],
        "tool_expectations": {
          "search": {
            "inputSchema.properties.query.type": "string",
            "inputSchema.properties.top_k.type": "integer",
            "inputSchema.properties.top_k.default": 10,
            "inputSchema.properties.federated.type": "boolean",
            "inputSchema.properties.federated.default": false
          },
          "drill": {
            "inputSchema.properties.ref.type": "string"
          },
          "feedback": {
            "inputSchema.properties.message.type": "string",
            "inputSchema.properties.message.minLength": 1,
            "inputSchema.properties.message.maxLength": 10000,
            "inputSchema.properties.severity.type": "string",
            "inputSchema.properties.context.type": "string",
            "inputSchema.properties.model.type": "string",
            "inputSchema.properties.harness.type": "string"
          }
        }
      }
    },
    {
      "_comment": "search returns ranked hits for the SurrealDB vector/graph query",
      "action": "call_tool",
      "name": "search",
      "arguments": {"query": "SurrealDB вектора graph", "top_k": 5},
      "expect": {
        "is_error": false,
        "content_text_contains": ["SurrealDB", "vectors", "graphs"]
      }
    }
  ]
}
